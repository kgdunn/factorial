# Application
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# PostgreSQL
POSTGRES_USER=doe_user
POSTGRES_PASSWORD=doe_password
POSTGRES_DB=doe_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Security — API key for endpoint authentication
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=change-me-to-a-random-secret

# Rate limiting for chat endpoint (slowapi format)
CHAT_RATE_LIMIT=10/minute

# JWT Authentication
# Generate secret with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS_ORIGINS: comma-separated list of origins the browser will load the frontend
# from. In production behind Caddy, set to the same origin as FRONTEND_URL and
# PUBLIC_API_URL below (no port):
#   IP-only: http://<YOUR_SERVER_IP>
#   Domain:  https://yourdomain.com
# In local dev, allow both the Vite dev server and the built static preview.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# SMTP Email (for signup approval flow)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=signup@factori.al
SMTP_USE_TLS=true

# Signup approval & first-time setup
# Admins are now stored in the `users` table (users.is_admin = true) rather than
# in an env var. Bootstrap the first admin with:
#   uv run python -m app.cli create-admin --email you@example.com
# That command prints a one-time setup link the admin follows to pick a password.
# Thereafter, admins can promote/demote other users from /admin/users.
#
# How long invite + setup + password-reset links stay valid.
INVITE_TOKEN_EXPIRE_HOURS=72
# FRONTEND_URL: public origin that users load in their browser. Embedded in outgoing
# emails (approval links, invite links, share links) — if wrong, those links break.
# In production behind Caddy this should match PUBLIC_API_URL below (no port):
#   IP-only: http://<YOUR_SERVER_IP>
#   Domain:  https://yourdomain.com
FRONTEND_URL=http://localhost:5173

# Shareable experiment links
SHARE_TOKEN_EXPIRE_DAYS=30
SHARE_TOKEN_LENGTH=32

# Exports (PDF requires system libs: libpango-1.0-0 libcairo2; Playwright requires Chromium)
EXPORTS_ENABLE_PDF=true
EXPORTS_CHROMIUM_PATH=
PUBLIC_SHARE_RATE_LIMIT=30/minute

# PUBLIC_API_URL: public origin the browser uses to reach the API. In production,
# Caddy fronts both frontend and backend on port 80/443 and routes /api to the
# backend — so use the same origin as FRONTEND_URL, with no port:
#   IP-only: http://<YOUR_SERVER_IP>
#   Domain:  https://yourdomain.com
# In local dev, the Vite dev server proxies /api to the backend on port 8000.
PUBLIC_API_URL=http://localhost:8000
