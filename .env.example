# Application
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# PostgreSQL
POSTGRES_USER=doe_user
POSTGRES_PASSWORD=doe_password
POSTGRES_DB=doe_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# PostgreSQL — backend test suite (APP_ENV=testing).
# Points at the ``postgres-test`` service in docker-compose.yml on port
# 5433. CI overrides POSTGRES_TEST_HOST/PORT to talk to the GitHub
# Actions ``services: postgres`` instance instead. The defaults are
# safe for local dev because the container is bound to 127.0.0.1:5433.
POSTGRES_TEST_USER=doe_user
POSTGRES_TEST_PASSWORD=doe_password
POSTGRES_TEST_DB=doe_test_db
POSTGRES_TEST_HOST=localhost
POSTGRES_TEST_PORT=5433

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Security — API key for endpoint authentication
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=change-me-to-a-random-secret

# Rate limiting for chat endpoint (slowapi format)
CHAT_RATE_LIMIT=10/minute

# Browser sessions. The session cookie is an opaque pointer to a row in
# the `sessions` table; there is no signing key and redeploys do not
# invalidate cookies. Idle = max gap between requests; Absolute = max
# total session age regardless of activity.
COOKIE_SESSION_IDLE_DAYS=30
COOKIE_SESSION_ABSOLUTE_DAYS=180

# CORS_ORIGINS: comma-separated list of origins the browser will load the frontend
# from. In production behind Caddy, set to the same origin as FRONTEND_URL and
# PUBLIC_API_URL below (no port):
#   IP-only: http://<YOUR_SERVER_IP>
#   Domain:  https://yourdomain.com
# In local dev, allow both the Vite dev server and the built static preview.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Per-turn chat timing instrumentation (engineering debugging only).
# A JSON-lines file rotated by a stdlib RotatingFileHandler. Empty string
# disables the timing log without breaking anything else. In dev the path
# is repo-relative; in production mount a volume and point at e.g.
# /var/log/factorial/timing.jsonl.
TIMING_LOG_PATH=logs/timing.jsonl
TIMING_LOG_MAX_BYTES=10485760
TIMING_LOG_BACKUP_COUNT=5

# SMTP Email (for signup approval flow)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=signup@factori.al
SMTP_USE_TLS=true

# Signup approval & first-time setup
# Admins are now stored in the `users` table (users.is_admin = true) rather than
# in an env var. Bootstrap the first admin with:
#   uv run python -m app.cli create-admin --email you@example.com
# That command prints a one-time setup link the admin follows to pick a password.
# Thereafter, admins can promote/demote other users from /admin/users.
#
# How long invite + setup + password-reset links stay valid.
INVITE_TOKEN_EXPIRE_HOURS=72
# FRONTEND_URL: public origin that users load in their browser. Embedded in outgoing
# emails (approval links, invite links, share links) — if wrong, those links break.
# In production behind Caddy this should match PUBLIC_API_URL below (no port):
#   IP-only: http://<YOUR_SERVER_IP>
#   Domain:  https://yourdomain.com
FRONTEND_URL=http://localhost:5173

# GeoIP — optional. Path to a MaxMind GeoLite2-Country.mmdb file used to
# resolve login IPs into ISO-3166 country codes for the admin Users panel.
# Download from https://www.maxmind.com/ (free account required) and drop
# the .mmdb file on the host. If empty or the file is missing, country
# lookup is silently skipped — logins still work. Refresh the file monthly.
GEOIP_COUNTRY_DB_PATH=

# Shareable experiment links
SHARE_TOKEN_EXPIRE_DAYS=30
SHARE_TOKEN_LENGTH=32

# Exports (PDF requires system libs: libpango-1.0-0 libcairo2; Playwright requires Chromium)
EXPORTS_ENABLE_PDF=true
EXPORTS_CHROMIUM_PATH=
PUBLIC_SHARE_RATE_LIMIT=30/minute

# PUBLIC_API_URL: public origin the browser uses to reach the API. In production,
# Caddy fronts both frontend and backend on port 80/443 and routes /api to the
# backend — so use the same origin as FRONTEND_URL, with no port:
#   IP-only: http://<YOUR_SERVER_IP>
#   Domain:  https://yourdomain.com
# In local dev, the Vite dev server proxies /api to the backend on port 8000.
PUBLIC_API_URL=http://localhost:8000

# Backup / restore scripts
# Ops-only config (S3 endpoint, bucket, AWS profile, healthchecks.io URL,
# failure webhook) lives in /etc/default/doe-backup on the VPS — NOT in
# this file. App and ops concerns are kept separate so operational
# config doesn't leak into cron's environment and application secrets
# don't leak into operator-owned config.
#
# Template:         deploy/etc-default/doe-backup.example
# Operator runbook: scripts/README.md
# Deployment docs:  docs/deployment/vps-guide.md (Phase 14)


# Tool execution safety
# ``TOOL_SAFE_MODE=true`` runs process-improve calls in an isolated
# worker subprocess with a wall-clock timeout and memory cap. Leave
# ``true`` in hosted deployments; tests set ``false`` via conftest.
TOOL_SAFE_MODE=true
TOOL_TIMEOUT_SECONDS=300
TOOL_MEMORY_MB=2048
TOOL_MAX_CELLS=1000000
TOOL_MAX_STRING=100000

# DOE upload (Excel/CSV ingestion via Claude). UPLOAD_MAX_BYTES caps the
# raw file size; UPLOAD_MAX_CELLS caps how much of the parsed 2D matrix
# we will hand to Claude in a single round-trip. The two together bound
# the cost of every upload-driven Anthropic call.
UPLOAD_MAX_BYTES=5242880
UPLOAD_MAX_CELLS=10000

# Hosted MCP endpoint (off by default). When enabled, ``/api/v1/mcp/tools``
# exposes the process-improve tool registry behind auth, rate limit, and a
# per-identity daily CPU-second budget.
MCP_ENABLED=false
MCP_RATE_LIMIT=30/minute
MCP_DAILY_CPU_SECONDS=3600
MCP_PATH_PREFIX=/mcp
