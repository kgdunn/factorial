<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>{{ experiment.name }} — Experiment Report</title>
  <style>
    @page { size: A4; margin: 18mm; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
      color: #222;
      font-size: 11pt;
      line-height: 1.45;
    }
    h1 { font-size: 20pt; margin: 0 0 4pt; }
    h2 { font-size: 13pt; margin: 20pt 0 8pt; border-bottom: 1pt solid #ccc; padding-bottom: 3pt; }
    .meta { color: #666; font-size: 10pt; margin-bottom: 16pt; }
    table { width: 100%; border-collapse: collapse; margin: 6pt 0; }
    th, td { border: 0.5pt solid #bbb; padding: 4pt 6pt; text-align: left; font-size: 10pt; }
    th { background: #f2f2f2; }
    figure { margin: 12pt 0; page-break-inside: avoid; }
    figure img { max-width: 100%; height: auto; border: 0.5pt solid #ddd; }
    figcaption {
      font-size: 9pt;
      color: #555;
      margin-top: 4pt;
      font-style: italic;
    }
    figcaption a { color: #2563eb; text-decoration: none; }
    .factor-list { margin: 0; padding-left: 18pt; }
    .footer {
      margin-top: 24pt;
      padding-top: 8pt;
      border-top: 0.5pt solid #ccc;
      font-size: 9pt;
      color: #888;
    }
    .footer a { color: #2563eb; text-decoration: none; }
  </style>
</head>
<body>

<h1>{{ experiment.name }}</h1>
<div class="meta">
  {% if experiment.design_type %}{{ experiment.design_type.replace('_', ' ') | title }} &middot; {% endif %}
  {% if experiment.n_factors %}{{ experiment.n_factors }} factor{{ 's' if experiment.n_factors != 1 else '' }} &middot; {% endif %}
  {% if experiment.n_runs %}{{ experiment.n_runs }} run{{ 's' if experiment.n_runs != 1 else '' }} &middot; {% endif %}
  Status: {{ experiment.status }}
</div>

{% if experiment.factors %}
<h2>Factors</h2>
<table>
  <thead>
    <tr>
      {% for key in experiment.factors[0].keys() %}<th>{{ key }}</th>{% endfor %}
    </tr>
  </thead>
  <tbody>
  {% for f in experiment.factors %}
    <tr>
      {% for key in experiment.factors[0].keys() %}<td>{{ f.get(key, '') }}</td>{% endfor %}
    </tr>
  {% endfor %}
  </tbody>
</table>
{% endif %}

<h2>{% if include_results %}Design Matrix &amp; Responses{% else %}Design Matrix{% endif %}</h2>
<table>
  <thead>
    <tr>
      {% for col in columns %}<th>{{ col }}</th>{% endfor %}
    </tr>
  </thead>
  <tbody>
  {% for row in rows %}
    <tr>
      {% for col in columns %}<td>{{ row.get(col, '') }}</td>{% endfor %}
    </tr>
  {% endfor %}
  </tbody>
</table>

{% if plots %}
<h2>Analysis</h2>
{% for plot in plots %}
  <figure id="plot-{{ plot.index }}">
    {% if share_url %}
      <a href="{{ share_url }}#plot-{{ plot.index }}"><img src="{{ plot.data_uri }}" alt="{{ plot.title }}" /></a>
    {% else %}
      <img src="{{ plot.data_uri }}" alt="{{ plot.title }}" />
    {% endif %}
    <figcaption>
      {{ plot.title }}.
      {% if share_url %}
        Interactive version: <a href="{{ share_url }}#plot-{{ plot.index }}">{{ share_url }}</a>
      {% endif %}
    </figcaption>
  </figure>
{% endfor %}
{% endif %}

<div class="footer">
  Generated by Agentic DOE &middot; {{ experiment.created_at.strftime('%Y-%m-%d') if experiment.created_at else '' }}
  {% if share_url %}&middot; <a href="{{ share_url }}">Open interactive version</a>{% endif %}
</div>

</body>
</html>
